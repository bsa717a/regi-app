// REGI — full data model (Postgres via Prisma)
// State-specific values live in state_rules.config jsonb (State Engine).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MemberRole {
  owner
  viewer

  @@map("member_role")
}

enum InviteStatus {
  pending
  accepted
  declined

  @@map("invite_status")
}

enum RegistrationType {
  passenger
  motorhome
  motorcycle
  trailer
  ohv
  snowmobile
  boat

  @@map("registration_type")
}

enum RenewalStatus {
  Requested
  DocumentsReceived
  Reviewing
  Processing
  Submitted
  Completed
  StickerMailed

  @@map("renewal_status")
}

enum DocumentType {
  registration
  insurance
  title
  emissions
  temp_permit
  other

  @@map("document_type")
}

enum NotificationChannel {
  push
  email
  sms

  @@map("notification_channel")
}

enum NotificationStatus {
  pending
  sent
  failed
  cancelled

  @@map("notification_status")
}

enum RegiChatRole {
  user
  assistant

  @@map("regi_chat_role")
}

enum PaymentStatus {
  pending
  requires_action
  succeeded
  failed
  refunded
  cancelled

  @@map("payment_status")
}

enum StaffRole {
  admin
  agent

  @@map("staff_role")
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id                String   @id @default(cuid())
  firebaseUid       String   @unique @map("firebase_uid")
  name              String?
  email             String   @unique
  phone             String?
  notificationPrefs Json     @default("{}") @map("notification_prefs")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  ownedHouseholds       Household[]       @relation("HouseholdOwner")
  memberships           HouseholdMember[]
  createdRegistrations  Registration[]    @relation("RegistrationCreator")
  requestedRenewals     Renewal[]         @relation("RenewalRequester")
  uploadedDocuments     Document[]        @relation("DocumentUploader")
  notifications         Notification[]
  payments              Payment[]
  pushTokens            PushToken[]
  regiChatMessages      RegiChatMessage[]

  @@map("users")
}

/// FCM web-push device tokens for a user (one row per browser/device).
model PushToken {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  token      String   @unique
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

model Household {
  id          String @id @default(cuid())
  name        String
  /// Unique: each user owns at most one household (household-of-one).
  ownerUserId String @unique @map("owner_user_id")

  owner         User           @relation("HouseholdOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  members       HouseholdMember[]
  registrations Registration[]

  @@map("households")
}

model HouseholdMember {
  id           String       @id @default(cuid())
  householdId  String       @map("household_id")
  /// Null while an invite is pending and the invitee has no account yet.
  userId       String?      @map("user_id")
  inviteEmail  String?      @map("invite_email")
  inviteToken  String?      @unique @map("invite_token")
  role         MemberRole
  inviteStatus InviteStatus @default(pending) @map("invite_status")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@unique([householdId, inviteEmail])
  @@index([userId])
  @@index([inviteEmail])
  @@map("household_members")
}

model Registration {
  id                    String           @id @default(cuid())
  householdId           String           @map("household_id")
  type                  RegistrationType
  vin                   String?
  plate                 String?
  state                 String           @db.Char(2)
  make                  String?
  model                 String?
  year                  Int?
  nickname              String?
  photoUrl              String?          @map("photo_url")
  photoGcsPath          String?          @map("photo_gcs_path")
  bodyClass             String?          @map("body_class")
  /// Type-specific fields (HIN, OHV class, trailer weight, boat length/HP, etc.).
  details               Json             @default("{}")
  registrationExpiresOn DateTime         @db.Date @map("registration_expires_on")
  createdBy             String           @map("created_by")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  household     Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  creator       User           @relation("RegistrationCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  renewals         Renewal[]
  documents        Document[]
  notifications    Notification[]
  photos           RegistrationPhoto[]
  maintenanceTasks MaintenanceTask[]
  maintenanceLogs  MaintenanceLog[]
  usageReadings    UsageReading[]

  @@index([householdId])
  @@index([createdBy])
  @@index([registrationExpiresOn])
  @@index([state])
  @@index([type])
  @@map("registrations")
}

/// Scheduled maintenance task for a registration (preset or custom).
model MaintenanceTask {
  id               String    @id @default(cuid())
  registrationId   String    @map("registration_id")
  name             String
  /// Stable key when created from a preset (e.g. "ohv_oil_change").
  presetKey        String?   @map("preset_key")
  intervalMonths   Int?      @map("interval_months")
  intervalHours    Float?    @map("interval_hours")
  intervalMiles    Float?    @map("interval_miles")
  notes            String?
  /// One-shot calendar reminder date ("remind me in X days"). Cleared after send.
  remindOn         DateTime? @db.Date @map("remind_on")
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  registration Registration     @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  logs         MaintenanceLog[]

  @@index([registrationId])
  @@index([registrationId, active])
  @@index([remindOn])
  @@map("maintenance_tasks")
}

/// Completed service entry for a registration (optionally linked to a task).
model MaintenanceLog {
  id               String   @id @default(cuid())
  registrationId   String   @map("registration_id")
  taskId           String?  @map("task_id")
  performedOn      DateTime @db.Date @map("performed_on")
  hoursAtService   Float?   @map("hours_at_service")
  milesAtService   Float?   @map("miles_at_service")
  costCents        Int?     @map("cost_cents")
  notes            String?
  /// Optional garage receipt photo in GCS.
  receiptGcsPath   String?  @map("receipt_gcs_path")
  receiptFilename  String?  @map("receipt_filename")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  registration Registration     @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  task         MaintenanceTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([registrationId])
  @@index([taskId])
  @@index([performedOn])
  @@map("maintenance_logs")
}

/// User-logged hours/odometer reading for a registration.
model UsageReading {
  id             String   @id @default(cuid())
  registrationId String   @map("registration_id")
  readingOn      DateTime @db.Date @map("reading_on")
  hours          Float?
  miles          Float?
  createdAt      DateTime @default(now()) @map("created_at")

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([registrationId, readingOn])
  @@map("usage_readings")
}

model RegistrationPhoto {
  id             String   @id @default(cuid())
  registrationId String   @map("registration_id")
  gcsPath        String   @map("gcs_path")
  isCover        Boolean  @default(false) @map("is_cover")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@map("registration_photos")
}

/// State Engine config lives in `config` jsonb. See src/lib/stateEngine/types.ts.
model StateRule {
  stateCode String  @id @db.Char(2) @map("state_code")
  config    Json
  active    Boolean @default(true)

  @@map("state_rules")
}

model Renewal {
  id                    String        @id @default(cuid())
  registrationId        String        @map("registration_id")
  status                RenewalStatus @default(Requested)
  requestedBy           String        @map("requested_by")
  feeBreakdown          Json          @default("{}") @map("fee_breakdown")
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")
  staffNotes            String?       @map("staff_notes") @db.Text

  // Timestamps for each concierge status transition
  requestedAt          DateTime  @default(now()) @map("requested_at")
  documentsReceivedAt  DateTime? @map("documents_received_at")
  reviewingAt          DateTime? @map("reviewing_at")
  processingAt         DateTime? @map("processing_at")
  submittedAt          DateTime? @map("submitted_at")
  completedAt          DateTime? @map("completed_at")
  stickerMailedAt      DateTime? @map("sticker_mailed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  requester    User         @relation("RenewalRequester", fields: [requestedBy], references: [id], onDelete: Restrict)
  documents    Document[]
  payments     Payment[]

  @@index([registrationId])
  @@index([requestedBy])
  @@index([status])
  @@map("renewals")
}

model Document {
  id               String       @id @default(cuid())
  registrationId   String       @map("registration_id")
  renewalId        String?      @map("renewal_id")
  type             DocumentType
  gcsPath          String       @map("gcs_path")
  originalFilename String       @map("original_filename")
  uploadedBy       String       @map("uploaded_by")
  createdAt        DateTime     @default(now()) @map("created_at")

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  renewal      Renewal?     @relation(fields: [renewalId], references: [id], onDelete: SetNull)
  uploader     User         @relation("DocumentUploader", fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([registrationId])
  @@index([renewalId])
  @@index([uploadedBy])
  @@index([type])
  @@map("documents")
}

model Notification {
  id             String              @id @default(cuid())
  userId         String              @map("user_id")
  registrationId String?             @map("registration_id")
  channel        NotificationChannel
  templateKey    String              @map("template_key")
  scheduledFor   DateTime            @map("scheduled_for")
  sentAt         DateTime?           @map("sent_at")
  status         NotificationStatus  @default(pending)
  /// Idempotency key for reminder scheduling (e.g. registrationId:templateKey:YYYY-MM-DD)
  dedupeKey      String              @unique @map("dedupe_key")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  /// One scheduled send per user × registration × channel × template × day
  @@unique([userId, registrationId, channel, templateKey, scheduledFor])
  @@index([userId])
  @@index([registrationId])
  @@index([scheduledFor])
  @@index([status])
  @@map("notifications")
}

model Payment {
  id                    String        @id @default(cuid())
  userId                String        @map("user_id")
  renewalId             String        @map("renewal_id")
  stripePaymentIntentId String?       @map("stripe_payment_intent_id")
  stripeChargeId        String?       @map("stripe_charge_id")
  stripeCustomerId      String?       @map("stripe_customer_id")
  amount                Int
  registrationFeeAmount Int           @default(0) @map("registration_fee_amount")
  regiServiceFeeAmount  Int           @default(0) @map("regi_service_fee_amount")
  lateFeeAmount         Int           @default(0) @map("late_fee_amount")
  status                PaymentStatus @default(pending)
  receiptUrl            String?       @map("receipt_url")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  renewal Renewal @relation(fields: [renewalId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([renewalId])
  @@index([status])
  @@map("payments")
}

model StaffUser {
  id          String    @id @default(cuid())
  firebaseUid String    @unique @map("firebase_uid")
  name        String
  role        StaffRole @default(agent)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("staff_users")
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  action    String
  entity    String
  before    Json?
  after     Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([actor])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_log")
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String
  state     String   @db.Char(2)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email, state])
  @@index([state])
  @@map("waitlist")
}

model RegiChatMessage {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  role      RegiChatRole
  content   String       @db.Text
  createdAt DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("regi_chat_messages")
}
