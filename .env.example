# =============================================================================
# REGI — Environment Variables
# Copy to `.env` for local development (read by both Next.js and Prisma CLI).
# Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=8080
# Public app origin for household invite links (falls back to request Host)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (Prisma / PostgreSQL)
# Local docker-compose maps host 5435 → container 5432
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://regi:regi_password@localhost:5435/regi

# -----------------------------------------------------------------------------
# Firebase Authentication — Client SDK (public / NEXT_PUBLIC_*)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Web Push (FCM) VAPID key for installed PWA clients.
# Firebase Console → Project settings → Cloud Messaging → Web Push certificates.
# Leave blank locally to disable the push toggle gracefully (no crash).
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# -----------------------------------------------------------------------------
# Firebase Admin SDK — Server-side token verification
# Prefer FIREBASE_* fields, or point GOOGLE_APPLICATION_CREDENTIALS at a
# service-account JSON file (e.g. under .secrets/, never committed).
# FIREBASE_PRIVATE_KEY may contain escaped newlines: use \n in the string.
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
GOOGLE_APPLICATION_CREDENTIALS=

# -----------------------------------------------------------------------------
# Google Cloud Storage (Document Vault)
# -----------------------------------------------------------------------------
GCS_BUCKET=regi-app-v1-documents
GCP_PROJECT_ID=regi-app-v1

# -----------------------------------------------------------------------------
# Email / notifications
# NOTIFICATION_EMAIL_PROVIDER: mock | sendgrid  (default: mock)
# -----------------------------------------------------------------------------
NOTIFICATION_EMAIL_PROVIDER=mock
# NOTIFICATION_PUSH_PROVIDER: fcm (default) | noop
NOTIFICATION_PUSH_PROVIDER=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=REGI

# -----------------------------------------------------------------------------
# Cron / Cloud Scheduler
# Shared secret for securing the daily reminder endpoint
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# Google Gemini — registration card OCR (server-side only)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Notes
# - NHTSA VIN decode (vPIC) is a free public API — no API key required.
# - Stripe / Twilio are intentionally omitted from this scaffold (later phases).
# -----------------------------------------------------------------------------
